# AgentForge Configuration
# Copy to .env and fill in your values

# API Settings
API_HOST=0.0.0.0
API_PORT=8765

# LLM Provider (one of: openai, anthropic, local)
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Stripe (for monetization)
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# Database (optional, SQLite default)
DATABASE_URL=sqlite:///data/agentforge.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/agentforge

# Rate Limiting
RATE_LIMIT_ENABLED=true
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=info
